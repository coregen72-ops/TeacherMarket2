{
  "name": "tutor-button",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "client:dev": "npm --prefix frontend run dev",
    "client:build": "cd frontend && npm run build",
    "build": "cd frontend && npm install && npm run build"
    "render-build": "prisma migrate deploy && prisma generate && cd frontend && npm ci && npm run build",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "install": "^0.13.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.7",
    "razorpay": "^2.9.2"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
